{
  "name": "wascer-gtm-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Google Tag Manager - Wascer",
  "license": "Apache-2.0",
  "author": "wascer",
  "homepage": "https://github.com/wascer/wascer-gtm-mcp-server",
  "main": "dist/index.js",
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "gtm",
    "wascer"
  ],
  "scripts": {
    "build": "tsc && chmod 755 dist/index.js",
