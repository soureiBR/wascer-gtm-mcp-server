    "hono": "^4.9.8",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.16.0"
  }
